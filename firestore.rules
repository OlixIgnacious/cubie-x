rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // Score Validation
    function isValidScore(data) {
      return data.userId == request.auth.uid
        && data.totalScore is number
        && data.distance is number
        && data.username is string
        && data.username.size() <= 32
        && data.timestamp == request.time;
    }

    // Scores Collection
    match /scores/{scoreId} {
      // Global leaderboard: everyone can list top scores
      allow list: if true;
      allow get: if true;
      
      // Only creation allowed, scores are immutable historical records
      allow create: if isSignedIn() && isValidScore(incoming());
      
      // No updates or deletes allowed for security/integrity
      allow update, delete: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow get: if true;
      allow create, update: if isSignedIn() 
        && userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().username is string
        && incoming().username.size() <= 32;
    }
  }
}

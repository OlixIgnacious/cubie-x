rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    // Score Validation
    function isValidScore(data) {
      return data.userId == request.auth.uid
        && data.totalScore is number
        && data.distance is number
        && data.username is string
        && data.username.size() <= 32
        && data.timestamp == request.time;
    }

    // Scores Collection
    match /scores/{scoreId} {
      allow list: if true;
      allow get: if true;
      allow create: if isSignedIn() 
        && isValidScore(incoming())
        && incoming().timestamp == request.time;
      allow update, delete: if false;
    }

    // User Profiles
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isSignedIn() 
        && userId == request.auth.uid
        && incoming().userId == request.auth.uid
        && incoming().username is string
        && incoming().username.size() <= 32
        && incoming().updatedAt == request.time;
      
      allow update: if isSignedIn()
        && userId == request.auth.uid
        && incoming().username is string
        && incoming().username.size() <= 32
        && incoming().updatedAt == request.time
        && request.time > resource.data.updatedAt + duration.value(30, 's');
    }
  }
}
